<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox prefHeight="600.0" prefWidth="700.0" spacing="20.0" stylesheets="@../css/style.css" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.LocationController">
   <padding>
      <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
   </padding>
   <children>
      <Label styleClass="title-label" text="Gestion des Locations" />
      
      <HBox spacing="20.0" VBox.vgrow="ALWAYS">
         <children>
            <TableView fx:id="locationTable" prefHeight="200.0" prefWidth="450.0" HBox.hgrow="ALWAYS">
              <columns>
                <TableColumn fx:id="colId" prefWidth="30.0" text="ID" />
                <TableColumn fx:id="colVoiture" prefWidth="100.0" text="Voiture" />
                <TableColumn fx:id="colClient" prefWidth="100.0" text="Client" />
                  <TableColumn fx:id="colDateDebut" prefWidth="80.0" text="Début" />
                  <TableColumn fx:id="colDateFin" prefWidth="80.0" text="Fin" />
                  <TableColumn fx:id="colPrixTotal" prefWidth="60.0" text="Prix" />
                  <TableColumn fx:id="colStatut" prefWidth="80.0" text="Statut" />
              </columns>
              <columnResizePolicy>
                  <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
              </columnResizePolicy>
            </TableView>
            
            <VBox prefWidth="250.0" styleClass="form-vbox">
               <children>
                  <Label text="Nouvelle Location" />
                  
                  <DatePicker fx:id="dateDebut" promptText="Date de début" />
                  <DatePicker fx:id="dateFin" promptText="Date de fin" />
                  <Button mnemonicParsing="false" onAction="#handleRechercheDispo" prefWidth="210.0" styleClass="action-button" text="Chercher voitures dispo." />
                  
                  <ComboBox fx:id="comboVoiture" prefWidth="210.0" promptText="Sélectionner Voiture" />
                  <ComboBox fx:id="comboClient" prefWidth="210.0" promptText="Sélectionner Client" />
                  
                  <HBox alignment="CENTER_LEFT" spacing="10.0">
                     <children>
                        <Button mnemonicParsing="false" onAction="#handleCalculPrix" styleClass="action-button" text="Calculer Prix" />
                        <TextField fx:id="txtPrixTotal" editable="false" prefWidth="90.0" promptText="Total" />
                     </children>
                     <VBox.margin>
                        <Insets top="10.0" />
                     </VBox.margin>
                  </HBox>
                  
                  <ComboBox fx:id="comboStatut" prefWidth="210.0" promptText="Statut de location">
                     <VBox.margin>
                        <Insets top="10.0" />
                     </VBox.margin>
                  </ComboBox>
                  
                  <HBox spacing="10.0">
                     <children>
                        <Button mnemonicParsing="false" onAction="#handleAdd" styleClass="action-button" text="Ajouter" />
                        <Button mnemonicParsing="false" onAction="#handleUpdate" styleClass="action-button" text="Modifier" />
                     </children>
                     <VBox.margin>
                        <Insets top="10.0" />
                     </VBox.margin>
                  </HBox>
                  <Button mnemonicParsing="false" onAction="#handleDelete" prefWidth="210.0" styleClass="action-button, delete-button" text="Supprimer">
                     <VBox.margin>
                        <Insets top="5.0" />
                     </VBox.margin>
                  </Button>
               </children>
            </VBox>
         </children>
      </HBox>
   </children>
</VBox>
