<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox prefHeight="600.0" prefWidth="700.0" spacing="20.0" stylesheets="@../css/style.css" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.LocationController">
   <padding>
      <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
   </padding>
   <children>
      <Label styleClass="title-label" text="Gestion des Locations" />
      
      <HBox alignment="CENTER_LEFT" spacing="10.0">
         <children>
            <TextField fx:id="searchField" prefWidth="300.0" promptText="Rechercher..." styleClass="search-field" />
            <Region HBox.hgrow="ALWAYS" />
            <Button mnemonicParsing="false" onAction="#handleExportCSV" styleClass="action-button, export-button" text="📥 Exporter CSV" />
         </children>
      </HBox>
      
      <HBox spacing="20.0" VBox.vgrow="ALWAYS">
         <children>
            <TableView fx:id="locationTable" prefHeight="200.0" prefWidth="450.0" HBox.hgrow="ALWAYS">
              <columns>
                <TableColumn fx:id="colId" prefWidth="30.0" text="ID" />
                <TableColumn fx:id="colVoiture" prefWidth="100.0" text="Voiture" />
                <TableColumn fx:id="colClient" prefWidth="100.0" text="Client" />
                  <TableColumn fx:id="colDateDebut" prefWidth="80.0" text="Début" />
                  <TableColumn fx:id="colDateFin" prefWidth="80.0" text="Fin" />
                  <TableColumn fx:id="colPrixTotal" prefWidth="60.0" text="Prix" />
                  <TableColumn fx:id="colStatut" prefWidth="80.0" text="Statut" />
              </columns>
              <columnResizePolicy>
                  <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
              </columnResizePolicy>
            </TableView>
            
            <VBox prefWidth="300.0" styleClass="form-vbox" spacing="12.0">
               <children>
                  <Label text="Détails de la Location" />
                  
                  <Label styleClass="section-subtitle" text="1. Dates" />
                  <DatePicker fx:id="dateDebut" prefWidth="280.0" promptText="Date de début" />
                  <DatePicker fx:id="dateFin" prefWidth="280.0" promptText="Date de fin" />
                  <Button mnemonicParsing="false" onAction="#handleRechercheDispo" prefWidth="280.0" styleClass="action-button, secondary-button" text="Chercher véhicules libres" />
                  
                  <Label styleClass="section-subtitle" text="2. Véhicule et Client">
                     <VBox.margin><Insets top="10.0" /></VBox.margin>
                  </Label>
                  <ComboBox fx:id="comboVoiture" prefWidth="280.0" promptText="Sélectionner Voiture" />
                  <ComboBox fx:id="comboClient" prefWidth="280.0" promptText="Sélectionner Client" />
                  
                  <Label styleClass="section-subtitle" text="3. Facturation">
                     <VBox.margin><Insets top="10.0" /></VBox.margin>
                  </Label>
                  <HBox alignment="CENTER_LEFT" spacing="10.0">
                     <children>
                        <Button mnemonicParsing="false" onAction="#handleCalculPrix" styleClass="action-button, secondary-button" text="Calculer" />
                        <TextField fx:id="txtPrixTotal" editable="false" HBox.hgrow="ALWAYS" promptText="Total MAD" />
                     </children>
                  </HBox>
                  
                  <Region VBox.vgrow="ALWAYS" />
                  
                  <HBox spacing="10.0">
                     <children>
                        <Button mnemonicParsing="false" onAction="#handleAdd" prefWidth="135.0" styleClass="action-button" text="Ajouter" />
                        <Button mnemonicParsing="false" onAction="#handleUpdate" prefWidth="135.0" styleClass="action-button" text="Modifier" />
                     </children>
                  </HBox>
                  <Button mnemonicParsing="false" onAction="#handleDelete" prefWidth="280.0" styleClass="action-button, delete-button" text="Supprimer" />
               </children>
            </VBox>
         </children>
      </HBox>
   </children>
</VBox>
