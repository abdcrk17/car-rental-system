<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox alignment="CENTER" prefHeight="600.0" prefWidth="900.0" styleClass="login-root" stylesheets="@../css/style.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.LoginController">
   <children>
      <VBox fx:id="loginBox" alignment="CENTER" maxHeight="-Infinity" maxWidth="-Infinity" prefHeight="400.0" prefWidth="400.0" spacing="20.0" styleClass="login-box">
         <children>
            <Label styleClass="login-title" text="Bienvenue">
               <font>
                  <Font name="System Bold" size="32.0" />
               </font>
               <VBox.margin>
                  <Insets bottom="20.0" />
               </VBox.margin>
            </Label>
            <Label styleClass="login-subtitle" text="Veuillez vous connecter pour continuer" textFill="#999999">
               <VBox.margin>
                  <Insets bottom="10.0" top="-20.0" />
               </VBox.margin>
            </Label>
            
            <VBox spacing="5.0">
               <children>
                  <Label text="Nom d'utilisateur" textFill="#cccccc" />
                  <TextField fx:id="usernameField" prefHeight="40.0" promptText="admin" styleClass="login-field" />
               </children>
               <VBox.margin>
                  <Insets left="30.0" right="30.0" />
               </VBox.margin>
            </VBox>
            
            <VBox spacing="5.0">
               <children>
                  <Label text="Mot de passe" textFill="#cccccc" />
                  <PasswordField fx:id="passwordField" prefHeight="40.0" promptText="••••••••" styleClass="login-field" />
               </children>
               <VBox.margin>
                  <Insets left="30.0" right="30.0" />
               </VBox.margin>
            </VBox>
            
            <Label fx:id="errorLabel" textFill="#ff4c4c" visible="false" />
            
            <Button fx:id="loginButton" defaultButton="true" mnemonicParsing="false" onAction="#handleLogin" prefHeight="45.0" prefWidth="340.0" styleClass="login-button" text="Se connecter">
               <font>
                  <Font name="System Bold" size="16.0" />
               </font>
               <VBox.margin>
                  <Insets top="10.0" />
               </VBox.margin>
            </Button>
         </children>
         <padding>
            <Insets bottom="30.0" top="30.0" />
         </padding>
      </VBox>
   </children>
</VBox>
