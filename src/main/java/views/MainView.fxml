<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane fx:id="mainPane" prefHeight="600.0" prefWidth="900.0" stylesheets="@../css/style.css" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.MainController">
   <left>
      <VBox prefHeight="600.0" prefWidth="200.0" spacing="10.0" styleClass="sidebar" BorderPane.alignment="CENTER">
         <children>
            <Label text="Car Rental" textFill="WHITE">
               <font>
                  <Font name="System Bold" size="24.0" />
               </font>
               <VBox.margin>
                  <Insets bottom="30.0" left="10.0" top="20.0" />
               </VBox.margin>
            </Label>
            <Button mnemonicParsing="false" onAction="#handleMenuVoitures" prefHeight="40.0" prefWidth="200.0" styleClass="nav-button" text="🚙 Voitures" />
            <Button mnemonicParsing="false" onAction="#handleMenuClients" prefHeight="40.0" prefWidth="200.0" styleClass="nav-button" text="👥 Clients" />
            <Button mnemonicParsing="false" onAction="#handleMenuLocations" prefHeight="40.0" prefWidth="200.0" styleClass="nav-button" text="📝 Locations" />
         </children>
      </VBox>
   </left>
</BorderPane>
